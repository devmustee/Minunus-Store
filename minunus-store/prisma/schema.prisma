generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum Role {
  ADMIN
  CLIENT
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  role         Role
  sales        Sale[]
  createdAt    DateTime @default(now())
}

model Product {
  id            Int        @id @default(autoincrement())
  name          String
  size          String
  sellingPrice  Int
  purchasePrice Int        @default(0)
  quantity      Int        @default(0)
  sales         Sale[]
  purchases     Purchase[]
  createdAt     DateTime   @default(now())

  @@unique([name, size], name: "name_size")
}

model Sale {
  id         Int      @id @default(autoincrement())
  productId  Int
  userId     Int
  quantity   Int
  unitPrice  Int
  totalPrice Int
  createdAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
}

model Purchase {
  id        Int      @id @default(autoincrement())
  productId Int
  quantity  Int
  unitCost  Int
  totalCost Int
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
}
